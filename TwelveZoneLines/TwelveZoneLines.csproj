<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Dalamud.NET.Sdk/15.0.0">
    <PropertyGroup>
        <Version>0.0.0.1</Version>
        <PackageProjectUrl>https://github.com/Abyeon/TwelveZoneLines</PackageProjectUrl>
        <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
        <IsPackable>false</IsPackable>
    </PropertyGroup>
    
    <PropertyGroup>
        <Author>Abyeon</Author>
        <Name>Twelve Zone Lines</Name>
        <PunchLine>See where you're going!</PunchLine>
        <Description>Brings FFXII's Zone Line's into XIV.</Description>
        <Tags>Ui, Utility, Xii</Tags>
        <RepoUrl>https://github.com/Abyeon/TwelveZoneLines</RepoUrl>
    </PropertyGroup>

    <ItemGroup>
        <Content Include="..\Data\travelIcon.png">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
            <Visible>false</Visible>
        </Content>
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="KamiToolKit" Version="2.0.17" />
    </ItemGroup>
</Project>
